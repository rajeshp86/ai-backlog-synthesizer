# =============================================================================
# Backlog Synthesizer — environment variable reference
# =============================================================================
# Copy this file to .env for local development.
# In production, inject variables via your platform's secrets manager
# (Azure Key Vault / Container Apps secrets, GitHub Actions secrets, etc.).
# NEVER commit a .env file containing real credentials.
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key — required for all Claude-backed presets.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API key — required for Free and Balanced presets.
# Free tier available at: https://aistudio.google.com/apikey
#
# ── GDPR / EU data-residency note ─────────────────────────────────────────────
# AI Studio (aistudio.google.com) processes data on Google's US infrastructure
# and is NOT covered by a GDPR Data Processing Addendum (DPA) suitable for
# regulated EU enterprise data.
#
# For EU deployments, use Vertex AI on a EU region instead:
#   1. Enable Vertex AI API in your Google Cloud project.
#   2. Set GOOGLE_GENAI_USE_VERTEXAI=1 and the variables below.
#   3. Model IDs are the same (gemini-2.5-flash, etc.) — no code changes needed.
#   4. Data stays within the EU region; Google's Cloud DPA covers processing.
#
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=europe-west1    # or europe-west4, europe-north1
# (Use Application Default Credentials or GOOGLE_APPLICATION_CREDENTIALS)
#
# Similarly, for Anthropic / Claude on EU infrastructure:
#   Anthropic offers a GDPR DPA — request it at privacy@anthropic.com.
#   There is no separate EU API endpoint; data is processed in the US but
#   the DPA provides the legal transfer mechanism under GDPR Art. 46.
GOOGLE_API_KEY=

# =============================================================================
# AUTH — Microsoft Entra ID SSO (enterprise)
# =============================================================================
# Set all four to enable SSO; omit to fall back to config/auth.yaml.
# ENTRA_TENANT_ID=your-tenant-guid
# ENTRA_TENANT_DOMAIN=yourcompany.onmicrosoft.com
# ENTRA_CLIENT_ID=your-app-registration-client-id
# ENTRA_CLIENT_SECRET=your-client-secret-value
# ENTRA_REDIRECT_URI=https://your-app.example.com/

# =============================================================================
# AUTH — username/password fallback (config/auth.yaml)
# =============================================================================
# Must be set to a cryptographically random secret in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# AUTH_COOKIE_SECRET=change-me-to-a-random-32-byte-hex-string

# Set to 1 ONLY in local development to bypass the demo-key safety check.
# Remove entirely before any production or staging deployment.
# AUTH_ALLOW_DEMO_SECRET=1

# Disable auth entirely for local dev (no password required).
# AUTH_DISABLED=1

# =============================================================================
# MODELS
# =============================================================================
# Override the default Claude model for all stages.
# ANTHROPIC_MODEL=claude-haiku-4-5

# =============================================================================
# LIVE INTEGRATIONS — Atlassian (Jira + Confluence)
# =============================================================================
# JIRA_BASE_URL=https://your-tenant.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-atlassian-api-token
# JIRA_PROJECT_KEY=PROJ
# JIRA_MAX_RESULTS=200      # 0 = no cap (fetches entire backlog)

# Confluence — auto-populated from JIRA_* above if on the same tenant.
# CONFLUENCE_BASE_URL=https://your-tenant.atlassian.net
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_API_TOKEN=
# CONFLUENCE_PAGE_ID=65830

# CONFLUENCE_MODE=mock      # mock | live
# JIRA_MODE=mock            # mock | live

# =============================================================================
# OBSERVABILITY
# =============================================================================
# Structured JSON logging (recommended in production containers).
# LOG_FORMAT=json           # text (default) | json
# LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# Prometheus metrics server port (scraped by your infra agent).
# METRICS_PORT=9090

# OpenTelemetry distributed tracing.
# OTEL_ENABLED=1
# OTEL_SERVICE_NAME=backlog-synthesizer
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-collector:4318/v1/traces

# =============================================================================
# RELIABILITY
# =============================================================================
# Per-run synthesis wall-clock timeout in seconds (auto-cancels orphaned runs).
# SYNTHESIS_TIMEOUT_SECONDS=600

# Maximum concurrent synthesis pipelines in one process.
# MAX_CONCURRENT_SYNTHESES=3

# Per-user request rate limits (independent of $ budget). 0 = disabled.
# MAX_SYNTHESES_PER_HOUR=5
# MAX_SYNTHESES_PER_DAY=20

# Per-agent LLM retry count on transient errors.
# AGENT_MAX_RETRIES=3

# Circuit-breaker thresholds (per LLM provider).
# CB_FAILURE_THRESHOLD=5
# CB_RECOVERY_TIMEOUT_SEC=60

# =============================================================================
# STORAGE
# =============================================================================
# Override persistent storage paths — point at a durable volume mount in
# production (e.g. an Azure Files share mounted at /app/backlog-data).
# LOGS_DIR=/app/backlog-data/logs
# OUTPUTS_DIR=/app/backlog-data/outputs

# Custom path for the SQLite audit-chain database.
# AUDIT_DB_PATH=/app/backlog-data/logs/audit_chain.db

# Retention policy: delete audit rows older than N days (0 = keep forever).
# AUDIT_LOG_RETENTION_DAYS=90

# Set to 0 to disable PII redaction in audit log prompts (on-prem only).
# AUDIT_PII_REDACTION=1

# =============================================================================
# VECTOR STORE / EMBEDDINGS
# =============================================================================
# Enable persistent NPZ embedding cache (speeds up repeated runs).
# MEMORY_PERSISTENT=0

# Enable ChromaDB persistent vector store (recommended for multi-replica).
# USE_CHROMADB=1

# ChromaDB HA server URL.
# When set, the app connects to an external ChromaDB HTTP server instead of
# the default file-backed PersistentClient (which is a single-volume SPOF).
# Deploy a ChromaDB container separately and point this at it to eliminate
# the SPOF and share the index across all replica pods.
#
# Single-pod / dev: leave unset — file-backed client is fine.
# Multi-replica prod: set to your HA Chroma server, e.g.:
#   CHROMADB_SERVER_URL=http://chroma.internal:8000
#
# Docker Compose example (add to docker-compose.yml):
#   chroma:
#     image: chromadb/chroma:latest
#     volumes:
#       - chroma_data:/chroma/.chroma
#     ports:
#       - "8000:8000"
# CHROMADB_SERVER_URL=http://chroma:8000

# Max file upload size in bytes (default 512 KB).
# MAX_UPLOAD_BYTES=524288

# Max estimated input tokens per synthesis run (transcript + constraints combined).
# Blocks runs whose input is too large before any LLM stage is charged.
# Default 50,000 tokens ≈ ~200 KB of text / ~150 pages.
# Raise this for unusually large wikis; lower it to tighten cost control.
# MAX_INPUT_TOKENS_PER_RUN=50000

# =============================================================================
# SECURITY ALERTING
# =============================================================================
# Webhook URL for security-finding alerts (Slack Incoming Webhook, MS Teams
# webhook.office.com URL, or any generic HTTPS endpoint).
# Set SECURITY_ALERT_MIN_SEVERITY to control the minimum severity that fires
# an alert: "info" | "warn" | "error" (default "error").
# SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# SECURITY_ALERT_MIN_SEVERITY=error

# PagerDuty Events API v2 routing key — alternative / additional to webhook.
# PAGERDUTY_ROUTING_KEY=your-32-char-routing-key

# =============================================================================
# BUDGET ENFORCEMENT (multi-replica)
# =============================================================================
# Redis connection string — enables shared daily spend counters across pods.
# REDIS_URL=redis://your-redis-host:6379/0

# Set to 1 to hard-fail at startup if Redis is unreachable.
# Recommended in multi-replica production to prevent per-pod budget bypass.
# REDIS_REQUIRED=1

# =============================================================================
# DEPLOYMENT
# =============================================================================
# Path checked by the polling loop for graceful shutdown (written by entrypoint.sh).
# SHUTDOWN_FLAG_PATH=/tmp/.shutdown_requested

# Client / organisation name shown on the login page.
# CLIENT_NAME=Accenture

# Streamlit server port.
# PORT=8502
